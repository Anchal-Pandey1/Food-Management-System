<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>BiteHub Admin Dashboard</title>

    <link rel="stylesheet" href="/css/adminHeader.css">
<link rel="stylesheet" href="/css/dashboard.css">
</head>
<body>

    <%- include("adminHeader") %>

    <div class="container">

        <!-- Welcome Section -->
        <div class="welcome">

            <div>

                <h1>Food Management</h1>

                <p>
                    Manage your restaurant menu and keep everything organized.
                </p>

            </div>

        </div>

        <!-- Statistics -->
        <div class="cards">

            <div class="card">

                <div class="icon">🍔</div>

                <h3>Total Foods</h3>

                <h2><%= totalFoods %></h2>

            </div>

            <div class="card">

                <div class="icon">📦</div>

                <h3>Total Orders</h3>

                <h2>0</h2>

            </div>

            <div class="card">

                <div class="icon">👤</div>

                <h3>Total Users</h3>

                <h2>0</h2>

            </div>

        </div>

        <!-- Search -->
       <div class="search-container">

            <input
                type="text"
                placeholder="Search Food..."
                class="search-box">

        </div>
        <h2 class="table-title">Food Menu</h2>

        <table>

            <thead>

                <tr>
                    <th>Image</th>
                    <th>Name</th>
                    <th>Price</th>
                    <th>Category</th>
                    <th>Description</th>
                    <th>Edit</th>
                    <th>Delete</th>
                </tr>

            </thead>

            <tbody>

                <% foods.forEach(food => { %>

                <tr>

                    <td>
                        <img src="/images/<%= food.image %>" alt="<%= food.name %>" class="food-img">
                    </td>

                    <td><%= food.name %></td>

                    <td>₹<%= food.price %></td>

                    <td><%= food.category %></td>

                    <td><%= food.description %></td>

                    <td>
                        <a href="/admin/edit-food/<%= food._id %>" class="edit-btn">
                            ✏ Edit
                        </a>
                    </td>

                    <td>
                        <a href="/admin/delete-food/<%= food._id %>"
                           class="delete-btn"
                           onclick="return confirm('Are you sure you want to delete this food?')">
                            🗑 Delete
                        </a>
                    </td>

                </tr>

                <% }) %>

            </tbody>

        </table>

    </div>

</body>
</html>