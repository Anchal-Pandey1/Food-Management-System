<!DOCTYPE html>
<html>
<head>
    <title>Dashboard</title>
</head>
<body>

<h1>Food Dashboard</h1>

<table border="1" cellpadding="10">

<tr>
    <th>Name</th>
    <th>Price</th>
    <th>Category</th>
    <th>Image</th>
    <th>Description</th>
    <th>Action</th>
    <th>Delete</th>
</tr>

<% foods.forEach(food => { %>

<tr>

    <td><%= food.name %></td>

    <td><%= food.price %></td>

    <td><%= food.category %></td>

    <td><%= food.image %></td>

    <td><%= food.description %></td>
    <td>
        <a href="/admin/edit-food/<%= food._id %>">
            Edit
        </a>
    </td>
    <td>
        <a href="/admin/delete-food/<%= food._id %>"
        onclick="return confirm('Are you sure you want to delete this food?')">
            Delete
        </a>
    </td>

</tr>

<% }) %>

</table>

</body>
</html>