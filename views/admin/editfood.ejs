<!DOCTYPE html>
<html lang="en">

<head>

    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>Edit Food</title>

    <link rel="stylesheet" href="/css/adminHeader.css">
    <link rel="stylesheet" href="/css/editFood.css">

</head>

<body>
    <%- include("adminHeader") %>

    <div class="page">
        <div class="form-card">

            <h1>✏️ Edit Food</h1>

            <p>Update the selected food item.</p>

            <form action="/admin/update-food/<%= food._id %>" method="POST">

                <div class="input-box">

                    <label>Food Name</label>

                    <input
                        type="text"
                        name="name"
                        value="<%= food.name %>"
                        required>

                </div>

                <div class="input-box">

                    <label>Price</label>

                    <input
                        type="number"
                        name="price"
                        value="<%= food.price %>"
                        required>

                </div>

                <div class="input-box">

                    <label>Category</label>

                    <input
                        type="text"
                        name="category"
                        value="<%= food.category %>"
                        required>

                </div>

                <div class="input-box">

                    <label>Image Name</label>

                    <input
                        type="text"
                        name="image"
                        value="<%= food.image %>"
                        required>

                </div>

                <div class="input-box">

                    <label>Description</label>

                    <textarea
                        name="description"
                        rows="4"
                        required><%= food.description %></textarea>

                </div>

                <div class="btn-group">

                    <button type="submit" class="update-btn">
                        💾 Update Food
                    </button>

                    <a href="/admin/dashboard" class="back-btn">
                        ← Back to Dashboard
                    </a>

                </div>

            </form>

        </div>
    </div>

</body>

</html>