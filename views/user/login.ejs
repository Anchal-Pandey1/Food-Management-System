<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Food Delivery - Login</title>

    <link rel="stylesheet" href="/css/login.css">
</head>
<body>

    <div class="login-box">

        <h2>🍕 Welcome Back</h2>

        <form action="#">

            <div class="input-box">
                <label>Email</label>
                <input
                    type="email"
                    placeholder="Enter your email"
                    required>
            </div>

            <div class="input-box">
                <label>Password</label>
                <input
                    type="password"
                    id="password"
                    placeholder="Enter your password"
                    required>
            </div>

            <div class="show-pass">
                <input
                    type="checkbox"
                    onclick="togglePassword()">
                    
                Show Password
            </div>

            <div class="options">

                <label>
                    <input type="checkbox">
                    Remember Me
                </label>

                <a href="#">Forgot Password?</a>

            </div>

            <button type="submit">
                Login
            </button>

            <p class="signup">
                Don't have an account?
                <a href="signup.html">Sign Up</a>
            </p>

        </form>

    </div>

    <script src="/login.js"></script>

</body>
</html>