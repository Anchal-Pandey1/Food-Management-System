<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>BiteHub</title>
   <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <header class="navbar">
      <div class="logo">🍽️ BiteHub</div>

      <nav class="nav-links">
        <a href="/drinks">Drinks</a>
        <a href="/food">Food</a>
        <a href="#">Restaurants</a>
        <a href="#">How it works</a>
        <a href="#">Contact</a>
      </nav>

      <div class="nav-actions">
        <a href="login"><button class="nav-btn">Login/SignIn</button></a>
        <a href="/signup">Signup</a>
        <a href="/admin/dashboard">Admin</a>
      </div>

      <div class="hamburger" id="hamburger">☰</div>

      <div class="mobile-menu" id="mobileMenu">
        <a href="#">Home</a>
        <a href="#">Compare</a>
        <a href="#">Restaurants</a>
        <a href="#">How it works</a>
        <a href="#">Contact</a>
      </div>
    </header>
    <header class="hero">
      <div class="nav-video">
        <video autoplay muted loop playsinline>
          <source src="videos/food.mp4" type="video/mp4" />
        </video>
        <div class="hero-content">
          <h3>Find the best Food at the Best Price</h3>
          <h2>Compare prices,offers and reviews from nearby restaurants</h2>
          <input type="text" placeholder="Search-food" />
        </div>
      </div>
    </header>
    <div class="second-sec">
      <div class="layout-content">
        <h2><b>Focus on Saving Money</b></h2>
        <p>
          We help food lovers <br />find the best meals <br />at the best prices
          <br />by comparing restaurants <br />in one place
        </p>
      </div>
    </div>
    <hr />
    <div class="layout-title">
      <h2 align="center">Smart Tools for Smarter Food Choices</h2>
    </div>
    <div class="layout">
      <div class="feature-card">
        <img src="/image/p1.jpeg" />
        <p>compare prices</p>
      </div>
      <div class="feature-card">
        <img src="/image/offer.jpeg" />
        <p>best offers</p>
      </div>
      <div class="feature-card">
        <img src="/image/verified.png" alt="" />
        <p>Verified reviews</p>
      </div>
      <div class="feature-card">
        <img src="/image/rest.avif" />
        <p>Nearby Restaurants</p>
      </div>
      <div class="feature-card">
        <img src="image/fo.jpg" />
        <p>Trending Foods</p>
      </div>
      <div class="feature-card">
        <img src="image/top.jpg" />
        <p>Top Rated</p>
      </div>
      <div class="feature-card">
        <img src="image/delivery time .png" alt="" />
        <p>Delivery Time</p>
      </div>
      <div class="feature-card">
        <img src="image/time.jpeg" alt="" />
        <p>Save More</p>
      </div>
    </div>
    <section class="food-section">
      <div class="food-heading">
        <h4>Explore Our</h4>
        <h1>Popular Food Categories</h1>
        <p>Discover delicious food options for every craving</p>
      </div>

      <div class="food-circle-container">
        <div class="center-circle">
          <h2>Popular Food Categories</h2>
        </div>

        <!-- Inner Ring -->
        <div class="orbit orbit-inner">
          <div class="category-card c1"><img src="image/i1.avif" /></div>
          <div class="category-card c2"><img src="image/i2.avif" /></div>
          <div class="category-card c3"><img src="image/i3.avif" /></div>
          <div class="category-card c4"><img src="image/i4.avif" /></div>
          <div class="category-card c5"><img src="image/i5.avif" /></div>
          <div class="category-card c6"><img src="image/i6.avif" /></div>
          <div class="category-card c7"><img src="image/i7.avif" /></div>
          <div class="category-card c8"><img src="image/i8.avif" /></div>
        </div>

        <!-- Outer Ring -->
        <div class="orbit orbit-outer">
          <div class="category-card o1"><img src="image/i9.avif" /></div>
          <div class="category-card o2"><img src="image/i10.avif" /></div>
          <div class="category-card o3"><img src="image/i11.avif" /></div>
          <div class="category-card o4"><img src="image/i12.avif" /></div>
          <div class="category-card o5"><img src="image/i13.avif" /></div>
          <div class="category-card o6"><img src="image/i14.avif" /></div>
          <div class="category-card o7"><img src="image/i15.avif" /></div>
          <div class="category-card o8"><img src="image/i16.avif" /></div>
          <div class="category-card o9"><img src="image/i17.avif" /></div>
          <div class="category-card o10"><img src="image/i18.avif" /></div>
          <div class="category-card o11"><img src="image/i19.avif" /></div>
          <div class="category-card o12"><img src="image/i20.avif" /></div>
          <div class="category-card o13"><img src="image/i21.avif" /></div>
          <div class="category-card o14"><img src="image/i22.avif" /></div>
          <div class="category-card o15"><img src="image/i23.avif" /></div>
          <div class="category-card o16"><img src="image/i24.avif" /></div>
        </div>
      </div>
    </section>
    <hr class="section-divider" />

    <section class="restaurants" id="restaurants">
      <div class="restaurant-heading">
        <h2>🍽️ Top restaurant Near You</h2>
        <p>Discover the highest-rated restaurants near your location.</p>
        <a href="restaurants.html" class="view-all">View All</a>
      </div>
      <div class="restaurant-container">
        <div class="restaurant-card">
          <img src="image/r1.jpeg" alt="hill n high" />
          <div class="restaurant-info">
            <h3>Hill 'N' High</h3>
            <p class="deal">🔥 Best Deal Today</p>
            <p>⭐️ 4.7</p>
            <p class="open">🟢 Open Now</p>
            <p class="closed">🔴 Closed</p>
            <div class="restaurant-tags">
              <span>🍕 Pizza</span>
              <span>🍛 North Indian</span>
              <span>🥤 Drinks</span>
            </div>
            <p>₹200 - ₹400</p>
            <p>📍 Civil Lines</p>
            <button>Compare Prices</button>
          </div>
        </div>
        <div class="restaurant-card">
          <img src="image/r2.jpg" alt="" />
          <div class="restaurant-info">
            <h3>El Chico</h3>
            <p class="deal">🔥 Best Deal Today</p>
            <p>⭐️ 4.1</p>
            <p class="open">🟢 Open Now</p>
            <p class="closed">🔴 Closed</p>
            <div class="restaurant-tags">
              <span>🍕 Pizza</span>
              <span>🍛 North Indian</span>
              <span>🥤 Drinks</span>
            </div>

            <p>₹200 - ₹400</p>
            <p>📍 Civil Lines</p>
            <button>Compare Prices</button>
          </div>
        </div>
        <div class="restaurant-card">
          <img src="image/r3.avif" alt="" />
          <div class="restaurant-info">
            <h3>Sardaar Ji Dhaba</h3>
            <p class="deal">🔥 Best Deal Today</p>
            <p>⭐️ 4.2</p>
            <p class="open">🟢 Open Now</p>
            <p class="closed">🔴 Closed</p>
            <div class="restaurant-tags">
              <span>🍕 Pizza</span>
              <span>🍛 North Indian</span>
              <span>🥤 Drinks</span>
            </div>
            <p>₹200 - ₹400</p>
            <p>📍 Civil Lines</p>
            <button>Compare Prices</button>
          </div>
        </div>
        <div class="restaurant-card">
          <img src="image/r4.jpg" alt="" />
          <div class="restaurant-info">
            <h3>The Roof Park</h3>
            <p class="deal">🔥 Best Deal Today</p>
            <p>⭐️ 4.3</p>
            <p class="open">🟢 Open Now</p>
            <p class="closed">🔴 Closed</p>
            <div class="restaurant-tags">
              <span>🍕 Pizza</span>
              <span>🍛 North Indian</span>
              <span>🥤 Drinks</span>
            </div>
            <p>₹200 - ₹400</p>
            <p>📍 Civil Lines</p>
            <button>Compare Prices</button>
          </div>
        </div>
        <div class="restaurant-card">
          <img src="image/r3.jpg" alt="" />
          <div class="restaurant-info">
            <h3>Jevnaar</h3>
            <p class="deal">🔥 Best Deal Today</p>
            <p>⭐️ 4.7</p>
            <p class="open">🟢 Open Now</p>
            <p class="closed">🔴 Closed</p>
            <div class="restaurant-tags">
              <span>🍕 Pizza</span>
              <span>🍛 North Indian</span>
              <span>🥤 Drinks</span>
            </div>
            <p>₹200 - ₹400</p>
            <p>📍 Civil Lines</p>
            <button>Compare Prices</button>
          </div>
        </div>
        <div class="restaurant-card">
          <img src="image/r5.jpg" alt="" />
          <div class="restaurant-info">
            <h3>The Yellow Chilli </h3>
            <p class="deal">🔥 Best Deal Today</p>
            <p>⭐️ 4.7</p>
            <p class="open">🟢 Open Now</p>
            <p class="closed">🔴 Closed</p>
            <div class="restaurant-tags">
              <span>🍕 Pizza</span>
              <span>🍛 North Indian</span>
              <span>🥤 Drinks</span>
            </div>
            <p>₹200 - ₹400</p>
            <p>📍 Civil Lines</p>
            <button>Compare Prices</button>
          </div>
        </div>
      </div>
    </section>
    <!-- ===================== START COMPARISON SECTION ===================== -->

    <section class="start-comparison" id="comparison">
      <div class="compare-box">
        <div class="compare-text">
          <h4>🚀 Experience BiteRadar in Action</h4>

          <h1>
            Watch How We Compare Prices
            <span>Across Nearby Restaurants</span>
          </h1>

          <p>
            We compare nearby restaurants based on your location, food prices,
            delivery time, offers, and ratings to help you choose the smartest
            option.
          </p>

          <button id="startBtn">🍽️ Start Comparing</button>
        </div>

        <div class="demo-video-card">
          <div class="video-header">
            <span class="dot red"></span>
            <span class="dot yellow"></span>
            <span class="dot green"></span>

            <h3>Live Demo</h3>
          </div>

          <video controls poster="image/demo-cover.jpg">
            <source src="videos/demo.mp4" type="video/mp4" />
            Your browser does not support the video tag.
          </video>

          <p class="demo-caption">
            Watch how BiteRadar finds the best restaurant near you in seconds.
          </p>

          <div class="video-features">
            <span>📍 Live Location</span>
            <span>💰 Price Comparison</span>
            <span>⭐ Best Restaurant</span>
          </div>
        </div>
      </div>
    </section>

    <!-- ===================== LOCATION POPUP ===================== -->

    <div class="popup-overlay" id="popup">
      <div class="popup">
        <div class="location-icon">📍</div>

        <h2>Allow Location Access</h2>

        <p>
          BiteRadar uses your location to discover nearby restaurants and
          compare food prices in real time.
        </p>

        <ul>
          <li>✔ Nearby Restaurants</li>
          <li>✔ Best Prices</li>
          <li>✔ Ratings & Reviews</li>
        </ul>

        <div class="popup-btns">
          <button class="allow" id="allowBtn">Allow Location</button>

          <button class="later" id="laterBtn">Maybe Later</button>
        </div>
      </div>
    </div>

    <!-- ===================== LOADING SCREEN ===================== -->

    <div class="loading-screen" id="loading">
      <div class="loader"></div>

      <h2>BiteRadar is Working...</h2>

      <div class="steps">
        <p id="step1">📍 Detecting Your Location...</p>
        <p id="step2">🍽️ Searching Nearby Restaurants...</p>
        <p id="step3">💰 Comparing Prices...</p>
        <p id="step4">🏆 Finding the Best Deal...</p>
      </div>
    </div>
    <section class="premium-section">
      <div class="floating-shape s1"></div>
      <div class="floating-shape s2"></div>
      <div class="floating-shape s3"></div>

      <div class="premium-container">
        <h2>Experience Food Ordering Like Never Before</h2>
        <p>
          Discover restaurants, compare meals, and order instantly with a
          smooth, modern experience.
        </p>

        <button class="glow-btn">Explore Now</button>
      </div>
    </section>
    <footer class="footer" id="footer">
      <div class="footer-container">
        <!-- Brand -->
        <div class="footer-col brand">
          <h2>BiteRadar</h2>
          <p>
            Discover, compare, and order the best food around you. Smart dining
            starts here.
          </p>
        </div>

        <!-- Quick Links -->
        <div class="footer-col">
          <h3>Quick Links</h3>
          <a href="#">Home</a>
          <a href="#">How it works</a>
          <a href="#">Compare</a>
          <a href="#">Restaurants</a>
        </div>

        <!-- Features -->
        <div class="footer-col">
          <h3>Features</h3>
          <a href="#">Price Comparison</a>
          <a href="#">Live Location</a>
          <a href="#">Best Deals</a>
          <a href="#">Fast Search</a>
        </div>

        <!-- Contact -->
        <div class="footer-col">
          <h3>Contact</h3>
          <a href="#">support@biteradar.com</a>
          <a href="#">+91 98765 43210</a>
          <a href="#">Prayagraj, India</a>
        </div>
      </div>

      <div class="footer-bottom">
        <p>© 2026 BiteRadar. All rights reserved.</p>
      </div>
    </footer>
</body>
</html>